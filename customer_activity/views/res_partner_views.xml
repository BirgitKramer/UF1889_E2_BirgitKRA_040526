<?xml version="1.0" encoding="UTF-8"?>
<!-- Declaracion XML estandar-->
<odoo>
    <!-- Vista formulario cliente -->

    <record id="view_partner_form_uf1889_e2" model="ir.ui.view">

        <field name="name">res.partner.form.uf1889_e2</field>

        <field name="model">res.partner</field>

        <field name="inherit_id" ref="base.view_partner_form"/>

        <!-- Arquitectura XML donde se aplica los cambios -->
        <field name="arch" type="xml">

            <!-- Xpath para localizar el nodo del formulario -->
            <xpath expr="//sheet" position="inside">
                <group string="Actividad comercial clientes">
                    <!-- campo calculado -->
                     <field name="activity_followup_count" readonly="1"/>
                </group>

            </xpath>

        </field>

    </record>

    <!-- Vista lista (tree) -->

    <record id="view_partner_list_uf1889_e2" model="ir.ui.view">

        <field name="name">res.partner.list.uf1889_e2</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>

        <!-- Arquitectura XML donde se aplica los cambios -->
        <field name="arch" type="xml">
            <xpath expr="//field[@name='complete_name']" position="after">
                <field name="activity_followup_count"/>
            </xpath>
        
        </field>

    </record>

</odoo>





        




